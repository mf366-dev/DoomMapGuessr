<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DoomMapGuessr.ViewModels"
             xmlns:strings="clr-namespace:DoomMapGuessr.Strings"
             mc:Ignorable="d" d:DesignWidth="1030" d:DesignHeight="720"
             x:Class="DoomMapGuessr.Views.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">
	<Design.DataContext>
		<vm:SettingsPageViewModel />
	</Design.DataContext>

	<Grid RowDefinitions="Auto, *, Auto">
		<StackPanel Grid.Row="0" Margin="0,12,0,12" Orientation="Horizontal" Spacing="8">
			<PathIcon Data="{DynamicResource Geometry.Settings400}" Width="32" Height="32" />
			<TextBlock Classes="h1" Text="{x:Static strings:Resources.Menu_Settings}" />
		</StackPanel>
		<ScrollViewer Grid.Row="1">
			<Grid RowDefinitions="Auto, Auto, Auto, *">
				<Border Grid.Row="0" Classes="card" Padding="16">
					<StackPanel Orientation="Vertical" Spacing="2">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<PathIcon Data="{DynamicResource Geometry.Globe400}" Width="24" Height="24" />
							<TextBlock Classes="h2" Text="{x:Static strings:Resources.Generics_Language}" />
						</StackPanel>
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Margin="24,8,0,0" VerticalAlignment="Center" TextAlignment="Right"
							           Text="{x:Static strings:Resources.Settings_Language_InputFieldPrompt}" />
							<ComboBox Margin="0,8,0,0" SelectedIndex="{Binding CurrentIndex}" ItemsSource="{Binding LanguageComboBoxItems}" />
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Grid.Row="1" Classes="card" Padding="16">
					<StackPanel Orientation="Vertical" Spacing="2">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<PathIcon Data="{DynamicResource Geometry.Brush400}" Width="24" Height="24" />
							<TextBlock Classes="h2" Text="{x:Static strings:Resources.Settings_UI}" />
						</StackPanel>
						<StackPanel Orientation="Vertical" Spacing="8">
							<ToggleSwitch Margin="24,8,0,0" OnContent="{x:Static strings:Resources.Settings_UI_UseCustomTheme}"
							              OffContent="{x:Static strings:Resources.Settings_UI_UseCustomTheme}"
							              IsChecked="{Binding CustomTheme}" />
							<ToggleSwitch Name="DarkThemeToggleSwitch" Margin="48,0,0,0"
							              OnContent="{x:Static strings:Resources.Settings_UI_DarkTheme}"
							              OffContent="{x:Static strings:Resources.Settings_UI_DarkTheme}"
							              IsChecked="{Binding DarkTheme}"
							              IsEnabled="{Binding CustomTheme}" />
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Grid.Row="2" Classes="card" Padding="16">
					<StackPanel Orientation="Vertical" Spacing="2">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<PathIcon Data="{DynamicResource Geometry.Image400}" Width="24" Height="24" />
							<TextBlock Classes="h2" Text="{x:Static strings:Resources.Settings_DoomScreenshots}" />
						</StackPanel>
						<TextBlock Classes="h3" Margin="24,8,0,8" Text="{x:Static strings:Resources.Settings_AspectRatio}" />
						<StackPanel Orientation="Horizontal" Spacing="8">
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_AspectRatio_MaintainProportions}" />
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center">16:9</RadioButton>
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center">4:3</RadioButton>
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center">1:1</RadioButton>
						</StackPanel>
						<TextBlock Classes="h3" Margin="24,8,0,8" Text="{x:Static strings:Resources.Generics_Color}" />
						<StackPanel Orientation="Vertical" Spacing="8">
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_Color_MaintainColor}" />
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_Color_Protanopia}" />
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_Color_Deuteranopia}" />
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_Color_Tritanopia}" />
							<RadioButton Margin="48,0,0,0" VerticalAlignment="Center"
							             Content="{x:Static strings:Resources.Settings_Color_Achromatopsia}" />
						</StackPanel>
						<TextBlock Classes="h3" Margin="24,8,0,8"
						           Text="{x:Static strings:Resources.Settings_DoomScreenshots_SourceBlacklist}" />
						<StackPanel Orientation="Vertical" Spacing="8" Margin="48,0,0,0">
							<ListBox MinWidth="50" CornerRadius="10">
								<ListBoxItem>google.com</ListBoxItem>
								<ListBoxItem>example.com</ListBoxItem>
								<ListBoxItem>some-random-unsafe-site.nope</ListBoxItem>
							</ListBox>
							<Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
								<Button Grid.Column="0" Margin="4">
									<StackPanel Spacing="8">
										<PathIcon Data="{DynamicResource Geometry.Add2400}" Width="16" Height="16" />
										<TextBlock Text="{x:Static strings:Resources.Generics_Add}" />
									</StackPanel>
								</Button>
								<Button Grid.Column="1" Margin="4">
									<StackPanel Spacing="8">
										<PathIcon Data="{DynamicResource Geometry.Edit400}" Width="16" Height="16" />
										<TextBlock Text="{x:Static strings:Resources.Generics_Edit}" />
									</StackPanel>
								</Button>
								<Button Grid.Column="3" Margin="4">
									<StackPanel Spacing="8">
										<PathIcon Data="{DynamicResource Geometry.Delete400}" Width="16" Height="16" />
										<TextBlock Text="{x:Static strings:Resources.Generics_Remove}" />
									</StackPanel>
								</Button>
								<Button Grid.Column="4" Classes="destructive" Margin="4">
									<StackPanel Spacing="8">
										<PathIcon Data="{DynamicResource Geometry.DeleteSweep400}" Width="16" Height="16" />
										<TextBlock Text="{x:Static strings:Resources.Generics_RemoveAll}" />
									</StackPanel>
								</Button>
							</Grid>
						</StackPanel>
					</StackPanel>
				</Border>
			</Grid>
		</ScrollViewer>
		<Button Grid.Row="2" Classes="primary" Margin="0,12,0,12" HorizontalAlignment="Right" Command="{Binding SaveSettingsCommand}">
			<StackPanel Spacing="8">
				<PathIcon Data="{DynamicResource Geometry.Save400}" Width="16" Height="16" />
				<TextBlock Text="{x:Static strings:Resources.Generics_Save}" />
			</StackPanel>
		</Button>
	</Grid>

</UserControl>